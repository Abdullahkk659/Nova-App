rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Avatars ───────────────────────────────────────────
    match /avatars/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024  // 5 MB max
        && request.resource.contentType.matches('image/.*');
    }

    // ── Post media ─────────────────────────────────────────
    match /posts/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 100 * 1024 * 1024  // 100 MB max
        && (
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType.matches('video/.*')
        );
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // ── Story media ────────────────────────────────────────
    match /stories/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 50 * 1024 * 1024  // 50 MB max
        && (
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType.matches('video/.*')
        );
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
